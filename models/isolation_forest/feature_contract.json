{
  "feature_names": [
    "flow_duration_sec",
    "flow_duration_nsec",
    "idle_timeout",
    "hard_timeout",
    "flags",
    "packet_count",
    "byte_count",
    "packet_count_per_second",
    "packet_count_per_nsecond",
    "byte_count_per_second",
    "byte_count_per_nsecond",
    "flow_duration_total_ns",
    "bytes_per_packet",
    "pkt_byte_rate_ratio"
